#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/led/led.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,physical-layout = &physical_layout0;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default";
        transform = <&default_transform>;

        keys
            = <&key_physical_attrs 100 100    0    0       0    0    0>   // 00: ESC [LEFT R0 C0]
            , <&key_physical_attrs 100 100  125    0       0    0    0>   // 01: F1 [LEFT R0 C1]
            , <&key_physical_attrs 100 100  225    0       0    0    0>   // 02: F2 [LEFT R0 C2]
            , <&key_physical_attrs 100 100  325    0       0    0    0>   // 03: F3 [LEFT R0 C3]
            , <&key_physical_attrs 100 100  425    0       0    0    0>   // 04: F4 [LEFT R0 C4]
            , <&key_physical_attrs 100 100  575    0       0    0    0>   // 05: F5 [LEFT R0 C5]
            , <&key_physical_attrs 100 100  675    0       0    0    0>   // 06: F6 [LEFT R0 C6]
            , <&key_physical_attrs 100 100 1150    0       0    0    0>   // 07: F7 [RIGHT R0 C0]
            , <&key_physical_attrs 100 100 1250    0       0    0    0>   // 08: F8 [RIGHT R0 C1]
            , <&key_physical_attrs 100 100 1400    0       0    0    0>   // 09: F9 [RIGHT R0 C2]
            , <&key_physical_attrs 100 100 1500    0       0    0    0>   // 10: F10 [RIGHT R0 C3]
            , <&key_physical_attrs 100 100 1600    0       0    0    0>   // 11: F11 [RIGHT R0 C4]
            , <&key_physical_attrs 100 100 1700    0       0    0    0>   // 12: F12 [RIGHT R0 C5]
            , <&key_physical_attrs 100 100 1850    0       0    0    0>   // 13: F13 [RIGHT R0 C6]
            , <&key_physical_attrs 100 100 1975    0       0    0    0>   // 14: PTR [RIGHT R0 C7]

            , <&key_physical_attrs 100 100    0  125       0    0    0>   // 15: ~ [LEFT R1 C0]
            , <&key_physical_attrs 100 100  100  125       0    0    0>   // 16: 1 [LEFT R1 C1]
            , <&key_physical_attrs 100 100  200  125       0    0    0>   // 17: 2 [LEFT R1 C2]
            , <&key_physical_attrs 100 100  300  125       0    0    0>   // 18: 3 [LEFT R1 C3]
            , <&key_physical_attrs 100 100  400  125       0    0    0>   // 19: 4 [LEFT R1 C4]
            , <&key_physical_attrs 100 100  500  125       0    0    0>   // 20: 5 [LEFT R1 C5]
            , <&key_physical_attrs 100 100  600  125       0    0    0>   // 21: 6 [LEFT R1 C6]
            , <&key_physical_attrs 100 100  700  125       0    0    0>   // 22: 7 [LEFT R1 C7]
            , <&key_physical_attrs 100 100 1150  125       0    0    0>   // 23: 7 [RIGHT R1 C0]
            , <&key_physical_attrs 100 100 1250  125       0    0    0>   // 24: 8 [RIGHT R1 C1]
            , <&key_physical_attrs 100 100 1350  125       0    0    0>   // 25: 9 [RIGHT R1 C2]
            , <&key_physical_attrs 100 100 1450  125       0    0    0>   // 26: 0 [RIGHT R1 C3]
            , <&key_physical_attrs 100 100 1550  125       0    0    0>   // 27: - [RIGHT R1 C4]
            , <&key_physical_attrs 100 100 1650  125       0    0    0>   // 28: = [RIGHT R1 C5]
            , <&key_physical_attrs 200 100 1750  125       0    0    0>   // 29: BACK [RIGHT R1 C6]
            , <&key_physical_attrs 100 100 1975  125       0    0    0>   // 30: INS [RIGHT R1 C7]

            , <&key_physical_attrs 150 100    0  225       0    0    0>   // 31: TAB [LEFT R2 C0]
            , <&key_physical_attrs 100 100  150  225       0    0    0>   // 32: Q [LEFT R2 C1]
            , <&key_physical_attrs 100 100  250  225       0    0    0>   // 33: W [LEFT R2 C2]
            , <&key_physical_attrs 100 100  350  225       0    0    0>   // 34: E [LEFT R2 C3]
            , <&key_physical_attrs 100 100  450  225       0    0    0>   // 35: R [LEFT R2 C4]
            , <&key_physical_attrs 100 100  550  225       0    0    0>   // 36: T [LEFT R2 C5]
            , <&key_physical_attrs 100 100  650  225       0    0    0>   // 37: Y [LEFT R2 C6]
            , <&key_physical_attrs 100 100 1100  225       0    0    0>   // 38: Y [RIGHT R2 C0]
            , <&key_physical_attrs 100 100 1200  225       0    0    0>   // 39: U [RIGHT R2 C1]
            , <&key_physical_attrs 100 100 1300  225       0    0    0>   // 40: I [RIGHT R2 C2]
            , <&key_physical_attrs 100 100 1400  225       0    0    0>   // 41: O [RIGHT R2 C3]
            , <&key_physical_attrs 100 100 1500  225       0    0    0>   // 42: P [RIGHT R2 C4]
            , <&key_physical_attrs 100 100 1600  225       0    0    0>   // 43: [ [RIGHT R2 C5]
            , <&key_physical_attrs 100 100 1700  225       0    0    0>   // 44: ] [RIGHT R2 C6]
            , <&key_physical_attrs 150 100 1800  225       0    0    0>   // 45: BACKSLASH [RIGHT R2 C7]

            , <&key_physical_attrs 175 100    0  325       0    0    0>   // 46: CAP [LEFT R3 C0]
            , <&key_physical_attrs 100 100  175  325       0    0    0>   // 47: A [LEFT R3 C1]
            , <&key_physical_attrs 100 100  275  325       0    0    0>   // 48: S [LEFT R3 C2]
            , <&key_physical_attrs 100 100  375  325       0    0    0>   // 49: D [LEFT R3 C3]
            , <&key_physical_attrs 100 100  475  325       0    0    0>   // 50: F [LEFT R3 C4]
            , <&key_physical_attrs 100 100  575  325       0    0    0>   // 51: G [LEFT R3 C5]
            , <&key_physical_attrs 100 100  675  325       0    0    0>   // 52: H [LEFT R3 C6]
            , <&key_physical_attrs 100 100 1125  325       0    0    0>   // 53: H [RIGHT R3 C0]
            , <&key_physical_attrs 100 100 1225  325       0    0    0>   // 54: J [RIGHT R3 C1]
            , <&key_physical_attrs 100 100 1325  325       0    0    0>   // 55: K [RIGHT R3 C2]
            , <&key_physical_attrs 100 100 1425  325       0    0    0>   // 56: L [RIGHT R3 C3]
            , <&key_physical_attrs 100 100 1525  325       0    0    0>   // 57: ; [RIGHT R3 C4]
            , <&key_physical_attrs 100 100 1625  325       0    0    0>   // 58: ' [RIGHT R3 C5]
            , <&key_physical_attrs 225 100 1725  325       0    0    0>   // 59: ENTER [RIGHT R3 C6]

            , <&key_physical_attrs 225 100    0  425       0    0    0>   // 60: SHIFT [LEFT R4 C0]
            , <&key_physical_attrs 100 100  225  425       0    0    0>   // 61: Z [LEFT R4 C1]
            , <&key_physical_attrs 100 100  325  425       0    0    0>   // 62: X [LEFT R4 C2]
            , <&key_physical_attrs 100 100  425  425       0    0    0>   // 63: C [LEFT R4 C3]
            , <&key_physical_attrs 100 100  525  425       0    0    0>   // 64: V [LEFT R4 C4]
            , <&key_physical_attrs 100 100  625  425       0    0    0>   // 65: B [LEFT R4 C5]
            , <&key_physical_attrs 100 100 1075  425       0    0    0>   // 66: B [RIGHT R4 C0]
            , <&key_physical_attrs 100 100 1175  425       0    0    0>   // 67: N [RIGHT R4 C1]
            , <&key_physical_attrs 100 100 1275  425       0    0    0>   // 68: M [RIGHT R4 C2]
            , <&key_physical_attrs 100 100 1375  425       0    0    0>   // 69: < [RIGHT R4 C3]
            , <&key_physical_attrs 100 100 1475  425       0    0    0>   // 70: > [RIGHT R4 C4]
            , <&key_physical_attrs 100 100 1575  425       0    0    0>   // 71: / [RIGHT R4 C5]
            , <&key_physical_attrs 175 100 1675  425       0    0    0>   // 72: SHIFT [RIGHT R4 C6]
            , <&key_physical_attrs 100 100 1875  475       0    0    0>   // 73: UP [RIGHT R4 C7]

            , <&key_physical_attrs 125 100    0  525       0    0    0>   // 74: CTL [LEFT R5 C0]
            , <&key_physical_attrs 100 100  125  525       0    0    0>   // 75: FN [LEFT R5 C1]
            , <&key_physical_attrs 125 100  225  525       0    0    0>   // 76: ALT [LEFT R5 C2]
            , <&key_physical_attrs 150 100 1475  525       0    0    0>   // 77: BLK [RIGHT R5 C3]
            , <&key_physical_attrs 100 100 1625  525       0    0    0>   // 78: BLK [RIGHT R5 C4]
            , <&key_physical_attrs 225 100  450  575       0    0    0>   // 79: SPACE [LEFT R5 C3]
            , <&key_physical_attrs 100 100  675  575       0    0    0>   // 80: BLK [LEFT R5 C4]
            , <&key_physical_attrs 275 100 1125  575       0    0    0>   // 81: SPACE [RIGHT R5 C0]
            , <&key_physical_attrs 100 100 1775  575       0    0    0>   // 82: LEFT [RIGHT R5 C5]
            , <&key_physical_attrs 100 100 1875  575       0    0    0>   // 83: DOWN [RIGHT R5 C6]
            , <&key_physical_attrs 100 100 1975  575       0    0    0>   // 84: RIGHT [RIGHT R5 C7]
            ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <16>;
        rows = <6>;

        map = <
            // KLE row 0
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)  RC(0,6)  RC(0,8)  RC(0,9)  RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14) RC(0,15)
            // KLE row 1
            RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)  RC(1,6)  RC(1,7)  RC(1,8)  RC(1,9)  RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14) RC(1,15)
            // KLE row 2
            RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)  RC(2,6)  RC(2,8)  RC(2,9)  RC(2,10) RC(2,11) RC(2,12) RC(2,13) RC(2,14) RC(2,15)
            // KLE row 3
            RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)  RC(3,6)  RC(3,8)  RC(3,9)  RC(3,10) RC(3,11) RC(3,12) RC(3,13) RC(3,14)
            // KLE row 4
            RC(4,0)  RC(4,1)  RC(4,2)  RC(4,3)  RC(4,4)  RC(4,5)  RC(4,8)  RC(4,9)  RC(4,10) RC(4,11) RC(4,12) RC(4,13) RC(4,14)
            // KLE row 5
            RC(4,15)
            // KLE row 6
            RC(5,0)  RC(5,1)  RC(5,2)  RC(5,11) RC(5,12)
            // KLE row 7
            RC(5,3)  RC(5,4)  RC(5,8)  RC(5,13) RC(5,14) RC(5,15)
        >;
    };
};

&pinctrl {
    spi3_default: spi3_default {
        group1 {
            psels = <NRF_PSEL(SPIM_MOSI, 0, 10)>;
        };
    };

    spi3_sleep: spi3_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_MOSI, 0, 10)>;
            low-power-enable;
        };
    };
};

&spi3 {
    compatible = "nordic,nrf-spim";
    status = "okay";
    pinctrl-0 = <&spi3_default>;
    pinctrl-1 = <&spi3_sleep>;
    pinctrl-names = "default", "sleep";

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";
        reg = <0>;
        spi-max-frequency = <4000000>;
        chain-length = <48>;
        spi-one-frame = <0x70>;
        spi-zero-frame = <0x40>;
        color-mapping = <LED_COLOR_ID_GREEN
                         LED_COLOR_ID_RED
                         LED_COLOR_ID_BLUE>;
    };
};
